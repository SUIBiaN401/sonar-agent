{
  "cfar": {
    "method": "os_cfar",
    "guard_cells": 4,
    "training_cells": 10,
    "false_alarm_rate": 1e-4,
    "median_filter_window": 11,
    "edge_angles_to_mask": [170, 181],
    "snr_profiles": {
      "high":    {"strong_thr": 1.5, "weak_thr": 0.8, "ms": 11},
      "medium":  {"strong_thr": 1.2, "weak_thr": 0.6, "ms": 11},
      "mid_low": {"strong_thr": 1.0, "weak_thr": 0.5, "ms": 11},
      "low":     {"strong_thr": 0.8, "weak_thr": 0.4, "ms": 11},
      "very_low":{"strong_thr": 0.5, "weak_thr": 0.2, "ms": 11}
    }
  },
  "cluster": {
    "algorithm": "dbscan",
    "eps": 10.0,
    "min_pts": 3
  },
  "tracker": {
    "max_gap": 4,
    "verify_signal": true,
    "process_noise": 0.001,
    "measurement_noise": 2.0,
    "min_confirmed": 3
  },
  "quality": {
    "length_weight": 30,
    "residual_weight": 30,
    "linearity_weight": 20,
    "continuity_weight": 20,
    "min_frames": 30,
    "quality_threshold": 70,
    "max_angle_span": 60,
    "angle_span_penalty_60": 10,
    "angle_span_penalty_40": 5
  },
  "peak_verify": {
    "residual_threshold": 2.0,
    "peak_valley_ratio": 1.5,
    "angle_tolerance": 8,
    "max_keep_mode": "n_est"
  },
  "merge": {
    "angle_threshold": 8,
    "gap_threshold": 30,
    "max_span": 25
  },
  "weak_recovery": {
    "temporal_window": 15,
    "angle_window": 10,
    "min_recovery_frames": 20,
    "min_residual": 0.8,
    "max_overlap_ratio": 0.5
  },
  "angle_split": {
    "jump_threshold": 12.0
  },
  "visualization": {
    "colormap": "Blues_r",
    "layout": [3, 9],
    "dpi": 150,
    "figsize": [27, 12]
  },
  "validation": {
    "min_trajectory_frames": 100,
    "min_residual_db": 2.0,
    "min_linearity_ratio": 0.5,
    "min_continuity_ratio": 0.3,
    "max_retry": 3
  },
  "paths": {
    "data_train": "../骗小米/data/训练",
    "data_test": "../骗小米/data/测试",
    "output": "output",
    "logs": "logs"
  }
}
